# ===========================================
# Terraform AI Agent - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your keys.

# --- LLM Provider (Pick ONE) ---
DEFAULT_MODEL=gemini/gemini-2.0-flash

# Google Gemini
GEMINI_API_KEY=your_gemini_key_here

# OpenAI (Alternative)
# OPENAI_API_KEY=your_openai_key_here

# Groq (Alternative - Fast)
# GROQ_API_KEY=your_groq_key_here

# Mistral (Alternative - Code Optimized)
# MISTRAL_API_KEY=your_mistral_key_here

# NVIDIA (Alternative)
# NVIDIA_API_KEY=your_nvidia_key_here

# Anthropic (Alternative)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Ollama (Local - No key needed)
# DEFAULT_MODEL=ollama/llama3

# --- FinOps (Infracost) ---
INFRACOST_API_KEY=your_infracost_key_here

# --- AWS Credentials (Required for --apply with AWS) ---
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_DEFAULT_REGION=us-east-1

# --- Dashboard ---
FLASK_SECRET_KEY=your_random_secret_here
