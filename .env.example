# ─── Terraform AI Agent — Environment Configuration ───
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/terraform_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=terraform_agent

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM API Keys (at least one required) ─────────────
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Cloud Credentials (optional — for live deployment) ─
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ARM_CLIENT_ID=
# ARM_CLIENT_SECRET=
# ARM_SUBSCRIPTION_ID=
# ARM_TENANT_ID=

# GOOGLE_APPLICATION_CREDENTIALS=

# ── Cost Estimation ──────────────────────────────────
INFRACOST_API_KEY=

# ── Application ──────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-a-random-string
RUNNING_IN_DOCKER=false
