-aks-production-public                                   \u2502\n\u2502                                                                              \u2502\n\u2502  ### Architecture Overview                                                   \u2502\n\u2502  This architecture provides a managed AKS cluster with public API access,    \u2502\n\u2502  Azure CNI, and integrated monitoring. It leverages Managed Identities for   \u2502\n\u2502  security and ACR integration.                                               \u2502\n\u2502                                                                              \u2502\n\u2502  #### Mermaid Diagram                                                        \u2502\n\u2502  ```mermaid                                                                  \u2502\n\u2502  graph TD                                                                    \u2502\n\u2502      subgraph \"Azure Resource Group\"                                         \u2502\n\u2502          VNet[Virtual Network]                                               \u2502\n\u2502          Subnet[Subnet]                                                      \u2502\n\u2502          NSG[Network Security Group]                                         \u2502\n\u2502          LAW[Log Analytics Workspace]                                        \u2502\n\u2502          ACR[Azure Container Registry]                                       \u2502\n\u2502          AKS[AKS Cluster]                                                    \u2502\n\u2502                                                                              \u2502\n\u2502          VNet --> Subnet                                                     \u2502\n\u2502          Subnet --> NSG                                                      \u2502\n\u2502          AKS --> LAW                                                         \u2502\n\u2502          AKS --> ACR                                                         \u2502\n\u2502          AKS --> Subnet                                                      \u2502\n\u2502      end                                                                     \u2502\n\u2502  ```                                                                         \u2502\n\u2502                                                                              \u2502\n\u2502  ### Terraform Implementation                                                \u2502\n\u2502                                                                              \u2502\n\u2502  #### 1. versions.tf                                                         \u2502\n\u2502  ```hcl                                                                      \u2502\n\u2502  terraform {                                                                 \u2502\n\u2502    required_version = \">= 1.6.0\"                                             \u2502\n\u2502    required_providers {                                                      \u2502\n\u2502      azurerm = {                                                             \u2502\n\u2502        source  = \"hashicorp/azurerm\"                                         \u2502\n\u2502        version = \">= 4.0.0\"                                                  \u2502\n\u2502      }                                                                       \u2502\n\u2502    }                                                                         \u2502\n\u2502  }                                                                           \u2502\n\u2502                                                                              \u2502\n\u2502  provider \"azurerm\" {                                                        \u2502\n\u2502    features {}                                                               \u2502\n\u2502  }                                                                           \u2502\n\u2502  ```                                                                         \u2502\n\u2502                                                                              \u2502\n\u2502  #### 2. variables.tf                                                        \u2502\n\u2502  ```hcl                                                                      \u2502\n\u2502  variable \"resource_group_name\" { type = string }                            \u2502\n\u2502  variable \"location\" { type = string }                                       \u2502\n\u2502  variable \"prefix\" { type = string }                                         \u2502\n\u2502  ```                                                                         \u2502\n\u2502                                                                              \u2502\n\u2502  #### 3. main.tf                                                             \u2502\n\u2502  ```hcl                                                                      \u2502\n\u2502  data \"azurerm_kubernetes_service_versions\" \"current\" {                      \u2502\n\u2502    location = var.location                                                   \u2502\n\u2502  }                                                                           \u2502\n\u2502                                                                              \u2502\n\u2502  resource \"azurerm_resource_group\" \"rg\" {                                    \u2502\n\u2502    name     = var.resource_group_name                                        \u2502\n\u2502    location = var.location                                                   \u2502\n\u2502  }                                                                           \u2502\n\u2502                                                                              \u2502\n\u2502  resource \"azurerm_log_analytics_workspace\" \"main\" {                         \u2502\n\u2502    name                = \"${var.prefix}-logs\"                                \u2502\n\u2502    location            = azurerm_resource_group.rg.location                  \u2502\n\u2502    resource_group_name = azurerm_resource_group.rg.name                      \u2502\n\u2502    sku                 = \"PerGB2018\"                                         \u2502\n\u2502  }                                                                           \u2502\n\u2502                                                                              \u2502\n\u2502  resource \"azurerm_virtual_network\" \"vnet\" {                                 \u2502\n\u2502    name                = \"${var.prefix}-vnet\"                                \u2502\n\u2502    address_space       = [\"10.0.0.0/16\"]                                     \u2502\n\u2502    location            = azurerm_resource_group.rg.location                  \u2502\n\u2502    resource_group_name = azurerm_resource_group.rg.name                      \u2502\n\u2502  }                                                                           \u2502\n\u2502                                                                              \u2502\n\u2502  resource \"azurerm_subnet\" \"aks\" {                                           \u2502\n\u2502    name                 = \"aks-subnet\"                                       \u2502\n\u2502    resource_group_name  = azurerm_resource_group.rg.name                     \u2502\n\u2502    virtual_network_name = azurerm_virtual_network.vnet.name                  \u2502\n\u2502    address_prefixes     = [\"10.0.1.0/24\"]                                    \u2502\n\u2502  }                                                                           \u2502\n\u2502                                                                              \u2502\n\u2502  resource \"azurerm_container_registry\" \"acr\" {                               \u2502\n\u2502    name                = \"${replace(var.prefix, \"-\", \"\")}acr\"                \u2502\n\u2502    resource_group_name = azurerm_resource_group.rg.name                      \u2502\n\u2502    location            = azurerm_resource_group.rg.location                  \u2502\n\u2502    sku                 = \"Standard\"                                          \u2502\n\u2502    admin_enabled       = false                                               \u2502\n\u2502  }                                                                           \u2502\n\u2502                                                                              \u2502\n\u2502  resource \"azurerm_kubernetes_cluster\" \"aks\" {                               \u2502\n\u2502    name                    = \"${var.prefix}-aks\"                             \u2502\n\u2502    location                = azurerm_resource_group.rg.location              \u2502\n\u2502    resource_group_name     = azurerm_resource_group.rg.name                  \u2502\n\u2502    dns_prefix              = var.prefix                                      \u2502\n\u2502    kubernetes_version      =                                                 \u2502\n\u2502  data.azurerm_kubernetes_service_versions.current.latest_version             \u2502\n\u2502    oidc_issuer_enabled     = true                                            \u2502\n\u2502    workload_identity_enabled = true                                          \u2502\n\u2502                                                                              \u2502\n\u2502    default_node_pool {                                                       \u2502\n\u2502      name                = \"system\"                                          \u2502\n\u2502      node_count          = 2                                                 \u2502\n\u2502      vm_size             = \"Standard_D16s_v5\"                                \u2502\n\u2502      vnet_subnet_id      = azurerm_subnet.aks.id                             \u2502\n\u2502      enable_auto_scaling = true                                              \u2502\n\u2502      min_count           = 2                                                 \u2502\n\u2502      max_count           = 5                                                 \u2502\n\u2502    }                                                                         \u2502\n\u2502                                                                              \u2502\n\u2502    identity { type = \"SystemAssigned\" }                                      \u2502\n\u2502                                                                              \u2502\n\u2502    network_profile {                                                         \u2502\n\u2502      network_plugin = \"azure\"                                                \u2502\n\u2502    }                                                                         \u2502\n\u2502                                                                              \u2502\n\u2502    oms_agent {                                                               \u2502\n\u2502      log_analytics_workspace_id = azurerm_log_analytics_workspace.main.id    \u2502\n\u2502    }                                                                         \u2502\n\u2502  }                                                                           \u2502\n\u2502                                                                              \u2502\n\u2502  resource \"azurerm_role_assignment\" \"acr_pull\" {                             \u2502\n\u2502    principal_id                     =                                        \u2502\n\u2502  azurerm_kubernetes_cluster.aks.kubelet_identity[0].object_id                \u2502\n\u2502    role_definition_name             = \"AcrPull\"                              \u2502\n\u2502    scope                            = azurerm_container_registry.acr.id      \u2502\n\u2502    skip_service_principal_aad_check = true                                   \u2502\n\u2502  }                                                                           \u2502\n\u2502  ```                                                                         \u2502\n\u2502                                                                              \u2502\n\u2502  #### 4. outputs.tf                                                          \u2502\n\u2502  ```hcl                                                                      \u2502\n\u2502  output \"kube_config\" {                                                      \u2502\n\u2502    value     = azurerm_kubernetes_cluster.aks.kube_config_raw                \u2502\n\u2502    sensitive = true                                                          \u2502\n\u2502  }                                                                           \u2502\n\u2502                                                                              \u2502\n\u2502  output \"acr_login_server\" {                                                 \u2502\n\u2502    value = azurerm_container_registry.acr.login_server                       \u2502\n\u2502  }                                                                           \u2502\n\u2502  ```                                                                         \u2502\n\u2502  ---------------------------                                                 \u2502\n\u2502                                                                              \u2502\n\u2502  ## MANDATORY RULES (FAILURE TO FOLLOW = BROKEN CODE)                        \u2502\n\u2502  1. You MUST use the `Write Terraform File` tool for EVERY SINGLE FILE you   \u2502\n\u2502  create.                                                                     \u2502\n\u2502  2. DO NOT WRITE PLAIN TEXT TERRAFORM. YOU MUST CALL THE TOOL.               \u2502\n\u2502  3. If you need to create 15 files, you MUST call the tool 15 times.         \u2502\n\u2502  4. Structure: Root `main.tf` calling modules in `modules/` directory.       \u2502\n\u2502     Module sources MUST be relative path strings (e.g., source =             \u2502\n\u2502  \"./modules/vpc\").                                                           \u2502\n\u2502  5. You MUST create a `README.md` in the project ROOT.                       \u2502\n\u2502                                                                              \u2502\n\u2502  ## HCL FORMATTING (CRITICAL)                                                \u2502\n\u2502  - NEVER use semicolons (;) to separate arguments. Use NEWLINES.             \u2502\n\u2502  - Every resource argument MUST be on its own line.                          \u2502\n\u2502  - Every closing brace } MUST be on its own line.                            \u2502\n\u2502  - BAD:  resource \"aws_subnet\" \"s1\" { vpc_id = aws_vpc.main.id; cidr_block   \u2502\n\u2502  = \"10.0.1.0/24\" }                                                           \u2502\n\u2502  - GOOD:                                                                     \u2502\n\u2502    resource \"aws_subnet\" \"s1\" {                                              \u2502\n\u2502      vpc_id     = aws_vpc.main.id                                            \u2502\n\u2502      cidr_block = \"10.0.1.0/24\"                                              \u2502\n\u2502    }                                                                         \u2502\n\u2502                                                                              \u2502\n\u2502  ## REQUIRED FILES                                                           \u2502\n\u2502  - Root files: Define the `terraform { required_providers { } }` block and   \u2502\n\u2502  `provider` block exactly once (e.g. in `versions.tf` or `main.tf`). DO NOT  \u2502\n\u2502  duplicate provider blocks across multiple files.                            \u2502\n\u2502  - Root `variables.tf`: Input variables (e.g., region).                      \u2502\n\u2502  - Root `outputs.tf`: Key outputs (endpoints, IDs, ARNs).                    \u2502\n\u2502                                                                              \u2502\n\u2502  ## EKS / INFRASTRUCTURE COMPLETENESS CHECKLIST                              \u2502\n\u2502  If creating EKS, you MUST include ALL of the following:                     \u2502\n\u2502  - At least 2 subnets across 2 different Availability Zones (EKS requires    \u2502\n\u2502  this).                                                                      \u2502\n\u2502  - Subnets must have `map_public_ip_on_launch = true` for public clusters.   \u2502\n\u2502  - IAM roles MUST have `aws_iam_role_policy_attachment` resources:           \u2502\n\u2502    * Cluster role: AmazonEKSClusterPolicy                                    \u2502\n\u2502    * Node role: AmazonEKSWorkerNodePolicy,                                   \u2502\n\u2502  AmazonEC2ContainerRegistryReadOnly, AmazonEKS_CNI_Policy                    \u2502\n\u2502  - EKS `vpc_config` must include `endpoint_public_access = true` for public  \u2502\n\u2502  clusters.                                                                   \u2502\n\u2502  - Node group must have `depends_on` referencing the IAM policy              \u2502\n\u2502  attachments.                                                                \u2502\n\u2502  - Subnets should be tagged: `kubernetes.io/cluster/<name> = shared`.        \u2502\n\u2502                                                                              \u2502\n\u2502  Project Slug: azure-aks-production-public                                   \u2502\n\u2502  ID: 3328f579-547d-4cb0-9f58-817968ba7a0e                                    \u2502\n\u2502                                                                              \u2502\n\u2502                                                                              \u2502\n\u2570\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256f\n\n\u256d\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 \ud83e\udd16 Agent Started \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u256e\n\u2502                                                                              \u2502\n\u2502  Agent: Senior Terraform Developer                                           \u2502\n\u2502                                                                              \u2502\n\u2502  Task: Based on the Architect's design, implement the Terraform project:     \u2502\n\u2502  azure-aks-production-public.                                                \u2502\n\u2502  --- ARCHITECTURE DESIGN ---                                                 \u2502\n\u2502  PROJECT_SLUG: azure-aks-production-public                                   \u2502\n\u2502                                                                              \u2502\n\u2502  ### Architecture Overview                                                   \u2502\n\u2502  This architecture provides a managed AKS cluster with public API access,    \u2502\n\u2502  Azure CNI, and integrated monitoring. It leverages Managed Identities for   \u2502\n\u2502  security and ACR integration.                                               \u2502\n\u2502                                                                              \u2502\n\u2502  #### Mermaid Diagram                                                        \u2502\